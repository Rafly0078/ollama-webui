# ============================================================================
# Local AI Bridge — Ollama upstream (SERVER-ONLY, hidden from the browser)
# The frontend calls /api/bridge/*; only the server reads this. Prefer this
# over NEXT_PUBLIC_API_URL so the upstream URL never ships in the client bundle.
# ============================================================================
OLLAMA_API_URL=https://my-ollama-api.example.com

# Legacy/public fallback. Still honored by the bridge if OLLAMA_API_URL is unset.
# Setting it also marks the app "configured" for the client. Optional now.
NEXT_PUBLIC_API_URL=https://my-ollama-api.example.com

# Set to "true" to hide chat (guest/static-only deploy with no model backend).
# NEXT_PUBLIC_DISABLE_BRIDGE=false

# ============================================================================
# Supabase — auth, database, storage. Leave blank to run in guest-only mode
# (localStorage persistence, no sign-in). URL + anon key are PUBLIC (safe in the
# browser under RLS). The service-role key is SECRET and server-only.
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# Tavily — web search (SERVER-ONLY, never shipped to the browser).
# Powers the Globe toggle in chat via /api/search. Get a key at tavily.com
# (free tier available). Leave unset to disable web search (route returns 501).
# ============================================================================
TAVILY_API_KEY=tvly-your-tavily-api-key
