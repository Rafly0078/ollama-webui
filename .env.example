# The external API endpoint that proxies to your local Ollama server.
# This is a PUBLIC variable (baked into the client bundle) — never put secrets here.
# Never use localhost in production; point this at your reachable tunnel/host.
#
# Examples:
#   NEXT_PUBLIC_API_URL=https://my-ollama-api.example.com
#   NEXT_PUBLIC_API_URL=https://ollama.mydomain.dev
NEXT_PUBLIC_API_URL=https://my-ollama-api.example.com
